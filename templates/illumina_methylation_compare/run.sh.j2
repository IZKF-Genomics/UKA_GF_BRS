#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$ROOT_DIR"

if [[ ! -f pixi.toml ]]; then
  echo "ERROR: missing required file: pixi.toml" >&2
  exit 1
fi
if [[ ! -f config/project.toml ]]; then
  echo "ERROR: missing required file: config/project.toml" >&2
  exit 1
fi
if [[ ! -f config/samples.csv ]]; then
  echo "ERROR: missing required file: config/samples.csv" >&2
  exit 1
fi
if [[ ! -f config/input_registry.csv ]]; then
  echo "ERROR: missing required file: config/input_registry.csv" >&2
  exit 1
fi
if [[ ! -f config/comparisons.csv ]]; then
  echo "ERROR: missing required file: config/comparisons.csv" >&2
  exit 1
fi
if ! command -v pixi >/dev/null 2>&1; then
  echo "ERROR: pixi not found on PATH" >&2
  exit 1
fi

echo "[INFO] Running Illumina methylation COMPARE pipeline for {{ ctx.params.study_name | default(ctx.template.id, true) }}"
echo "[INFO] Root: $ROOT_DIR"

echo "[INFO] Installing/updating pixi environment"
pixi install

echo "[INFO] Repairing Bioconductor annotation environment if needed"
pixi run Rscript scripts/repair_bioc_env.R

SYNC_ON_RUN="$(pixi run Rscript -e 'cfg <- RcppTOML::parseTOML("config/project.toml"); v <- TRUE; if (!is.null(cfg$input$sync_samples_on_run)) v <- cfg$input$sync_samples_on_run; cat(tolower(as.character(v)))' 2>/dev/null || echo true)"
# if [[ "$SYNC_ON_RUN" =~ ^(true|t|1|yes|y)$ ]]; then
#   echo "[INFO] Syncing sample sheets"
#   pixi run sync-samples
# else
#   echo "[INFO] Skipping sample sync because input.sync_samples_on_run is disabled"
# fi

echo "[INFO] Validating project configuration"
pixi run check

mkdir -p reports

echo "[INFO] Rendering 01_dmp.qmd"
pixi run quarto render 01_dmp.qmd --to html --output-dir reports --no-clean

echo "[INFO] Rendering 02_dmr.qmd"
pixi run quarto render 02_dmr.qmd --to html --output-dir reports --no-clean

echo "[INFO] Rendering 03_enrichment.qmd"
pixi run quarto render 03_enrichment.qmd --to html --output-dir reports --no-clean

echo "[INFO] Rendering 04_drilldown.qmd"
pixi run quarto render 04_drilldown.qmd --to html --output-dir reports --no-clean

echo "[INFO] Rendering 00_index.qmd"
pixi run quarto render 00_index.qmd --to html --output-dir reports --no-clean

echo "[INFO] Complete. Reports written to reports/"
