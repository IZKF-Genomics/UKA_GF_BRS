#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$ROOT_DIR"

mkdir -p results/logs
LOG_FILE="results/logs/run_$(date +%Y%m%d_%H%M%S).log"

required=(pixi.toml config/project.toml config/samples.csv)
for f in "${required[@]}"; do
  if [[ ! -f "$f" ]]; then
    echo "ERROR: missing required file: $f" >&2
    exit 1
  fi
done
if [[ ! -f config/input_registry.csv && ! -f config/input_runs.csv ]]; then
  echo "ERROR: missing input run configuration (config/input_registry.csv or config/input_runs.csv)" >&2
  exit 1
fi

echo "[INFO] Running Illumina methylation COMPARE pipeline for {{ ctx.params.study_name | default(ctx.template.id, true) }}" | tee -a "$LOG_FILE"
echo "[INFO] Root: $ROOT_DIR" | tee -a "$LOG_FILE"

if command -v pixi >/dev/null 2>&1; then
  :
else
  echo "ERROR: pixi not found on PATH" | tee -a "$LOG_FILE" >&2
  exit 1
fi

pixi install 2>&1 | tee -a "$LOG_FILE"
SYNC_ON_RUN="$(pixi run Rscript -e 'cfg <- RcppTOML::parseTOML(\"config/project.toml\"); v <- TRUE; if (!is.null(cfg$input$sync_samples_on_run)) v <- cfg$input$sync_samples_on_run; cat(tolower(as.character(v)))' 2>/dev/null || echo true)"
if [[ \"$SYNC_ON_RUN\" =~ ^(true|t|1|yes|y)$ ]]; then
  pixi run sync-samples 2>&1 | tee -a "$LOG_FILE"
fi
pixi run check 2>&1 | tee -a "$LOG_FILE"
pixi run render 2>&1 | tee -a "$LOG_FILE"

echo "[INFO] Complete. Reports written to reports/" | tee -a "$LOG_FILE"
