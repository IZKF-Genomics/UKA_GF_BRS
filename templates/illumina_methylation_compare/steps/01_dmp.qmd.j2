```{r setup, echo=TRUE, warning=FALSE, message=FALSE}
source("../common.R")
ensure_dirs("..")
cfg <- load_config("../config/project.toml")
samples <- load_samples("../config/samples.csv")
group_map <- load_group_map(coalesce_chr(cfg$input$group_map_file, "../config/group_map.csv"))
samples <- apply_group_map(samples, group_map, group_col = cfg$groups$primary_group_col)
if (!isTRUE(cfg$dmp$enabled)) {
  cat("DMP step disabled in config.\n")
  knitr::knit_exit()
}
if (!requireNamespace("limma", quietly = TRUE)) log_error("Package 'limma' is required")

obj <- load_analysis_inputs(cfg, samples)
beta <- get_beta_matrix(obj)
mval <- get_m_matrix(obj)
pdata <- get_pdata(obj)
ann <- get_annotation_df(obj)
meta <- merge_input_metadata(beta, pdata, samples)
group_col <- cfg$groups$primary_group_col
if (!(group_col %in% names(meta))) log_error("Group column not found in merged metadata:", group_col)

comparisons <- resolve_enabled_comparisons(cfg, meta)
out_summary <- list()
out_results <- list()

for (i in seq_len(nrow(comparisons))) {
  cmp <- comparisons[i, , drop = FALSE]
  cmp_id <- cmp$comparison_id[[1]]
  cmp_name <- cmp$comparison_name[[1]]
  base_group <- cmp$base_group[[1]]
  target_group <- cmp$target_group[[1]]
  cmp_alpha <- if (is.finite(cmp$alpha[[1]])) cmp$alpha[[1]] else cfg$dmp$alpha
  cmp_delta <- if (is.finite(cmp$delta_beta_min[[1]])) cmp$delta_beta_min[[1]] else cfg$dmp$delta_beta_min
  cmp_covars <- cmp$covariates[[1]]
  if (length(cmp_covars) == 0) cmp_covars <- unlist(cfg$dmp$covariates)

  keep_samples <- meta[[group_col]] %in% c(base_group, target_group)
  meta2 <- meta[keep_samples, , drop = FALSE]
  mat_beta <- beta[, keep_samples, drop = FALSE]
  mat_model <- if (isTRUE(cfg$dmp$use_m_values)) mval[, keep_samples, drop = FALSE] else mat_beta

  meta2[[group_col]] <- factor(meta2[[group_col]], levels = c(base_group, target_group))
  counts <- table(meta2[[group_col]])
  if (as.integer(counts[[base_group]]) < 2 || as.integer(counts[[target_group]]) < 2) {
    log_warn("Skipping comparison", cmp_id, "because one group has <2 samples")
    next
  }

  covars <- intersect(cmp_covars, names(meta2))
  design_vars <- c(group_col, covars)
  form <- stats::as.formula(paste("~", paste(design_vars, collapse = " + ")))
  design <- model.matrix(form, data = meta2)

  fit <- limma::lmFit(mat_model, design)
  fit <- limma::eBayes(fit)
  coef_name <- paste0(group_col, target_group)
  if (!(coef_name %in% colnames(fit$coefficients))) {
    coef_candidates <- colnames(fit$coefficients)[grepl(group_col, colnames(fit$coefficients), fixed = TRUE)]
    coef_name <- if (length(coef_candidates) > 0) coef_candidates[[1]] else NA_character_
  }
  if (is.na(coef_name)) {
    log_warn("Skipping comparison", cmp_id, "because no limma coefficient was found")
    next
  }

  res <- limma::topTable(fit, coef = coef_name, number = Inf, sort.by = "P", adjust.method = cfg$dmp$adjust_method)
  res$CpG <- rownames(res)
  delta_beta <- rowMeans(mat_beta[, meta2[[group_col]] == target_group, drop = FALSE], na.rm = TRUE) -
    rowMeans(mat_beta[, meta2[[group_col]] == base_group, drop = FALSE], na.rm = TRUE)
  res$delta_beta <- delta_beta[res$CpG]

  if ("Name" %in% names(ann)) {
    res <- dplyr::left_join(tibble::as_tibble(res), ann, by = c("CpG" = "Name"))
  } else {
    res <- tibble::as_tibble(res)
  }

  res <- dplyr::mutate(
    res,
    comparison_id = cmp_id,
    comparison_name = cmp_name,
    base_group = base_group,
    target_group = target_group,
    alpha = cmp_alpha,
    delta_beta_min = cmp_delta,
    significant = adj.P.Val <= cmp_alpha & abs(delta_beta) >= cmp_delta
  )

  cmp_dir_tbl <- file.path("../results/tables/comparisons", cmp_id)
  cmp_dir_fig <- file.path("../results/figures/comparisons", cmp_id)
  dir.create(cmp_dir_tbl, recursive = TRUE, showWarnings = FALSE)
  dir.create(cmp_dir_fig, recursive = TRUE, showWarnings = FALSE)

  write_table(res, file.path(cmp_dir_tbl, "dmp_table.csv"))
  write_table(dplyr::filter(res, significant), file.path(cmp_dir_tbl, "dmp_significant.csv"))

  p <- ggplot(res, aes(delta_beta, -log10(P.Value), color = significant)) +
    geom_point(alpha = 0.6) +
    scale_color_manual(values = c("FALSE" = "grey70", "TRUE" = "firebrick")) +
    labs(
      title = paste(cmp_name, "(", target_group, "vs", base_group, ")"),
      x = "Delta beta (target - base)",
      y = "-log10(P)"
    )
  save_plot(p, file.path(cmp_dir_fig, "dmp_volcano.png"), width = 8, height = 5)

  out_results[[cmp_id]] <- res
  out_summary[[cmp_id]] <- tibble::tibble(
    comparison_id = cmp_id,
    comparison_name = cmp_name,
    base_group = base_group,
    target_group = target_group,
    n_base = as.integer(counts[[base_group]]),
    n_target = as.integer(counts[[target_group]]),
    n_total = ncol(mat_beta),
    n_sig_cpg = sum(res$significant, na.rm = TRUE)
  )
}

if (length(out_results) == 0) log_error("No comparisons produced DMP output")

dmp_summary <- dplyr::bind_rows(out_summary)
dmp_all <- dplyr::bind_rows(out_results)

save_rds(out_results, "../results/rds/dmp_by_comparison.rds")
write_table(dmp_summary, "../results/tables/dmp_comparisons_summary.csv")
write_table(dmp_all, "../results/tables/dmp_all_comparisons.csv")
```

