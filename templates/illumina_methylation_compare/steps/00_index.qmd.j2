```{r setup, echo=TRUE, warning=FALSE, message=FALSE}
source("../common.R")
ensure_dirs("..")
cfg <- load_config("../config/project.toml")
samples <- load_samples("../config/samples.csv")
gm <- load_group_map(coalesce_chr(cfg$input$group_map_file, "../config/group_map.csv"))
samples <- apply_group_map(samples, gm, group_col = cfg$groups$primary_group_col)
comparisons <- resolve_enabled_comparisons(cfg, samples)
read_if <- function(path) if (file.exists(path)) readr::read_csv(path, show_col_types = FALSE) else NULL
run_summary <- read_if("../results/tables/input_run_summary.csv")
dmp_summary <- read_if("../results/tables/dmp_comparisons_summary.csv")

overview_tbl <- tibble::tibble(
  metric = c("project_name", "array_type", "genome_build", "input_registry_file", "group_map_file", "comparisons_file", "n_enabled_input_runs", "n_enabled_comparisons", "n_samples"),
  value = c(
    cfg$project$name,
    cfg$project$array_type,
    cfg$project$genome_build,
    cfg$input$input_registry_file,
    cfg$input$group_map_file,
    cfg$comparisons$comparisons_file,
    if (is.null(run_summary)) NA else nrow(run_summary),
    nrow(comparisons),
    nrow(samples)
  )
)

obj <- load_analysis_inputs(cfg, samples)
beta <- get_beta_matrix(obj)
pdata <- get_pdata(obj)
meta <- merge_input_metadata(beta, pdata, samples)

n_keep <- min(5000, nrow(beta))
var_idx <- order(matrixStats::rowVars(beta), decreasing = TRUE)
if (length(var_idx) > n_keep) var_idx <- var_idx[seq_len(n_keep)]
beta_var <- beta[var_idx, , drop = FALSE]
pc <- stats::prcomp(t(beta_var), center = TRUE, scale. = FALSE)
pca_df <- tibble::as_tibble(pc$x[, 1:2, drop = FALSE])
pca_df$sample_id <- colnames(beta_var)
pca_df <- dplyr::left_join(pca_df, meta, by = "sample_id")

p_group <- ggplot2::ggplot(pca_df, ggplot2::aes(PC1, PC2, color = .data[[cfg$groups$primary_group_col]])) +
  ggplot2::geom_point(alpha = 0.8) +
  ggplot2::labs(title = "All-sample PCA", color = cfg$groups$primary_group_col)
save_plot(p_group, "../results/figures/all_samples_pca_by_group.png", width = 8, height = 5)

color_run <- if ("run_id" %in% names(pca_df)) "run_id" else cfg$groups$primary_group_col
p_run <- ggplot2::ggplot(pca_df, ggplot2::aes(PC1, PC2, color = .data[[color_run]])) +
  ggplot2::geom_point(alpha = 0.8) +
  ggplot2::labs(title = "All-sample PCA", color = color_run)
save_plot(p_run, "../results/figures/all_samples_pca_by_run.png", width = 8, height = 5)

write_table(pca_df, "../results/tables/all_samples_pca.csv")
```

