```{r setup, echo=TRUE, warning=FALSE, message=FALSE}
source("common.R")
ensure_dirs(".")
cfg <- load_config("config/project.toml")
if (!requireNamespace("plotly", quietly = TRUE)) log_error("Package 'plotly' is required")
if (!requireNamespace("htmlwidgets", quietly = TRUE)) log_error("Package 'htmlwidgets' is required")
if (!requireNamespace("uwot", quietly = TRUE)) log_error("Package 'uwot' is required")
if (!requireNamespace("Rtsne", quietly = TRUE)) log_error("Package 'Rtsne' is required")
if (!requireNamespace("pheatmap", quietly = TRUE)) log_error("Package 'pheatmap' is required")
samples <- load_samples("config/samples.csv")
gm <- load_group_map(coalesce_chr(cfg$input$group_map_file, "config/group_map.csv"))
samples <- apply_group_map(samples, gm, group_col = cfg$groups$primary_group_col)
comparisons <- resolve_enabled_comparisons(cfg, samples)
read_if <- function(path) if (file.exists(path)) readr::read_csv(path, show_col_types = FALSE) else NULL
run_summary <- read_if("results/tables/input_run_summary.csv")
dmp_summary <- read_if("results/tables/dmp_comparisons_summary.csv")

overview_tbl <- tibble::tibble(
  metric = c("project_name", "array_type", "genome_build", "input_registry_file", "group_map_file", "comparisons_file", "n_enabled_input_runs", "n_enabled_comparisons", "n_samples"),
  value = c(
    cfg$project$name,
    cfg$project$array_type,
    cfg$project$genome_build,
    cfg$input$input_registry_file,
    cfg$input$group_map_file,
    cfg$comparisons$comparisons_file,
    if (is.null(run_summary)) NA else nrow(run_summary),
    nrow(comparisons),
    nrow(samples)
  )
)
write_table(overview_tbl, "results/tables/overview_table.csv")
write_table(comparisons, "results/tables/enabled_comparisons.csv")

obj <- load_analysis_inputs(cfg, samples)
beta <- get_beta_matrix(obj)
pdata <- get_pdata(obj)
meta <- merge_input_metadata(beta, pdata, samples)

batch_cfg <- cfg$batch
batch_configured <- !is.null(batch_cfg) && parse_bool(batch_cfg$enabled, default = FALSE)
batch_applied <- !is.null(obj$batch_correction) && isTRUE(obj$batch_correction$enabled)
batch_method <- if (batch_applied) {
  coalesce_chr(obj$batch_correction$method, "")
} else {
  coalesce_chr(if (!is.null(batch_cfg)) batch_cfg$method else NULL, "")
}
batch_col <- if (batch_applied) {
  coalesce_chr(obj$batch_correction$batch_col, "")
} else {
  coalesce_chr(if (!is.null(batch_cfg)) batch_cfg$batch_col else NULL, "")
}
batch_preserve <- if (batch_applied) {
  config_chr_vector(obj$batch_correction$preserve_cols)
} else {
  config_chr_vector(if (!is.null(batch_cfg)) batch_cfg$preserve_cols else NULL)
}
batch_status <- dplyr::case_when(
  batch_applied ~ "Applied",
  batch_configured ~ "Configured but not applied",
  TRUE ~ "Disabled"
)
batch_tbl <- tibble::tibble(
  metric = c("status", "configured", "applied", "method", "batch_column", "preserved_covariates"),
  value = c(
    batch_status,
    as.character(batch_configured),
    as.character(batch_applied),
    ifelse(nzchar(batch_method), batch_method, NA_character_),
    ifelse(nzchar(batch_col), batch_col, NA_character_),
    ifelse(length(batch_preserve) > 0, paste(batch_preserve, collapse = ", "), NA_character_)
  )
)
write_table(batch_tbl, "results/tables/batch_correction_summary.csv")

embedding_palette <- function(values) {
  vals <- sort(unique(as.character(stats::na.omit(values))))
  if (length(vals) == 0) return(character(0))
  stats::setNames(grDevices::hcl.colors(length(vals), "Dark 3"), vals)
}

theme_pub <- function() {
  ggplot2::theme_minimal(base_size = 13) +
    ggplot2::theme(
      plot.title = ggplot2::element_text(face = "bold", size = 16),
      plot.subtitle = ggplot2::element_text(color = "#4A4A4A"),
      axis.title = ggplot2::element_text(face = "bold"),
      panel.grid.minor = ggplot2::element_blank(),
      legend.position = "bottom",
      legend.title = ggplot2::element_text(face = "bold")
    )
}

build_embedding_plot <- function(df, x, y, color_var, title) {
  palette_vals <- embedding_palette(df[[color_var]])
  ggplot2::ggplot(df, ggplot2::aes(.data[[x]], .data[[y]], color = .data[[color_var]])) +
    ggplot2::geom_point(size = 3, alpha = 0.9) +
    ggplot2::scale_color_manual(values = palette_vals) +
    ggplot2::labs(
      title = title,
      subtitle = paste(nrow(df), "samples"),
      x = x,
      y = y,
      color = color_var
    ) +
    theme_pub()
}

embedding_hover_text <- function(df, axis_labels) {
  group_vals <- if ("group" %in% names(df)) as.character(df$group) else rep("", nrow(df))
  run_vals <- if ("run_id" %in% names(df)) as.character(df$run_id) else rep("", nrow(df))
  out <- paste0(
    "<b>", df$sample_id, "</b><br>",
    "Group: ", group_vals, "<br>",
    "Run: ", run_vals, "<br>",
    axis_labels[[1]], ": ", sprintf("%.3f", df[[axis_labels[[1]]]]), "<br>",
    axis_labels[[2]], ": ", sprintf("%.3f", df[[axis_labels[[2]]]])
  )
  if (length(axis_labels) >= 3) {
    out <- paste0(
      out,
      "<br>",
      axis_labels[[3]], ": ", sprintf("%.3f", df[[axis_labels[[3]]]])
    )
  }
  out
}

build_plotly_2d <- function(df, x, y, color_var, title) {
  palette_vals <- embedding_palette(df[[color_var]])
  df$hover_text <- embedding_hover_text(df, c(x, y))
  plotly::layout(
    plotly::plot_ly(
      data = df,
      x = stats::as.formula(paste0("~`", x, "`")),
      y = stats::as.formula(paste0("~`", y, "`")),
      type = "scatter",
      mode = "markers",
      color = stats::as.formula(paste0("~`", color_var, "`")),
      colors = unname(palette_vals),
      text = ~hover_text,
      hoverinfo = "text",
      marker = list(size = 8, opacity = 0.85)
    ),
    title = list(text = title),
    legend = list(orientation = "h", y = -0.2),
    xaxis = list(title = x),
    yaxis = list(title = y)
  )
}

build_plotly_3d <- function(df, x, y, z, color_var, title) {
  palette_vals <- embedding_palette(df[[color_var]])
  df$hover_text <- embedding_hover_text(df, c(x, y, z))
  plotly::layout(
    plotly::plot_ly(
      data = df,
      x = stats::as.formula(paste0("~`", x, "`")),
      y = stats::as.formula(paste0("~`", y, "`")),
      z = stats::as.formula(paste0("~`", z, "`")),
      type = "scatter3d",
      mode = "markers",
      color = stats::as.formula(paste0("~`", color_var, "`")),
      colors = unname(palette_vals),
      text = ~hover_text,
      hoverinfo = "text",
      marker = list(size = 4.5, opacity = 0.85)
    ),
    title = list(text = title),
    legend = list(orientation = "h", y = -0.15),
    scene = list(
      xaxis = list(title = x),
      yaxis = list(title = y),
      zaxis = list(title = z)
    )
  )
}

save_widget <- function(widget, path) {
  dir.create(dirname(path), recursive = TRUE, showWarnings = FALSE)
  htmlwidgets::saveWidget(widget, file = path, selfcontained = TRUE)
  invisible(path)
}

n_keep <- min(5000, nrow(beta))
var_idx <- order(matrixStats::rowVars(beta), decreasing = TRUE)
if (length(var_idx) > n_keep) var_idx <- var_idx[seq_len(n_keep)]
beta_var <- beta[var_idx, , drop = FALSE]
embedding_input <- t(beta_var)
sample_id_order <- rownames(embedding_input)

set.seed(42)
pc <- stats::prcomp(embedding_input, center = TRUE, scale. = FALSE)
pca_df <- tibble::as_tibble(pc$x[, 1:3, drop = FALSE])
pca_df$sample_id <- sample_id_order
pca_df <- dplyr::left_join(pca_df, meta, by = "sample_id")

n_samples <- nrow(embedding_input)
set.seed(42)
umap_coords <- uwot::umap(
  embedding_input,
  n_components = 3,
  n_neighbors = min(15, max(2, n_samples - 1)),
  min_dist = 0.2,
  metric = "euclidean",
  init = "spca",
  verbose = FALSE
)
colnames(umap_coords) <- c("UMAP1", "UMAP2", "UMAP3")
umap_df <- tibble::as_tibble(umap_coords)
umap_df$sample_id <- sample_id_order
umap_df <- dplyr::left_join(umap_df, meta, by = "sample_id")

tsne_perplexity <- min(30, max(1, floor((n_samples - 1) / 3)))
set.seed(42)
tsne_fit <- Rtsne::Rtsne(
  embedding_input,
  dims = 3,
  perplexity = tsne_perplexity,
  pca = TRUE,
  check_duplicates = FALSE,
  verbose = FALSE
)
colnames(tsne_fit$Y) <- c("TSNE1", "TSNE2", "TSNE3")
tsne_df <- tibble::as_tibble(tsne_fit$Y)
tsne_df$sample_id <- sample_id_order
tsne_df <- dplyr::left_join(tsne_df, meta, by = "sample_id")

group_col <- cfg$groups$primary_group_col

save_plot(
  build_embedding_plot(pca_df, "PC1", "PC2", group_col, "PCA: all samples"),
  "results/figures/all_samples_pca.png",
  width = 9,
  height = 6
)
save_plot(
  build_embedding_plot(umap_df, "UMAP1", "UMAP2", group_col, "UMAP: all samples"),
  "results/figures/all_samples_umap.png",
  width = 9,
  height = 6
)
save_plot(
  build_embedding_plot(tsne_df, "TSNE1", "TSNE2", group_col, "t-SNE: all samples"),
  "results/figures/all_samples_tsne.png",
  width = 9,
  height = 6
)

write_table(pca_df, "results/tables/all_samples_pca.csv")
write_table(umap_df, "results/tables/all_samples_umap.csv")
write_table(tsne_df, "results/tables/all_samples_tsne.csv")

heatmap_n <- min(150, nrow(beta))
heatmap_idx <- order(matrixStats::rowVars(beta), decreasing = TRUE)
if (length(heatmap_idx) > heatmap_n) heatmap_idx <- heatmap_idx[seq_len(heatmap_n)]
heatmap_mat <- beta[heatmap_idx, , drop = FALSE]
heatmap_mat_scaled <- t(scale(t(heatmap_mat)))
heatmap_mat_scaled[is.na(heatmap_mat_scaled)] <- 0

heatmap_annotation <- meta[match(colnames(heatmap_mat_scaled), meta$sample_id), , drop = FALSE]
rownames(heatmap_annotation) <- heatmap_annotation$sample_id
annotation_cols <- intersect(c(group_col, "run_id", "dataset_id"), names(heatmap_annotation))
heatmap_annotation <- heatmap_annotation[, annotation_cols, drop = FALSE]
if (ncol(heatmap_annotation) == 0) heatmap_annotation <- NULL

annotation_colors <- list()
if (!is.null(heatmap_annotation)) {
  heatmap_annotation <- as.data.frame(heatmap_annotation, stringsAsFactors = FALSE)
  for (nm in names(heatmap_annotation)) {
    heatmap_annotation[[nm]] <- factor(as.character(heatmap_annotation[[nm]]))
    palette_vals <- embedding_palette(as.character(heatmap_annotation[[nm]]))
    if (length(palette_vals) > 0) annotation_colors[[nm]] <- palette_vals
  }
}

heatmap_breaks <- seq(-2.5, 2.5, length.out = 101)
heatmap_palette <- grDevices::colorRampPalette(
  c("#16324F", "#EDEBE4", "#8C271E")
)(length(heatmap_breaks) - 1)

sample_order <- order(
  if (!is.null(heatmap_annotation) && group_col %in% names(heatmap_annotation)) heatmap_annotation[[group_col]] else colnames(heatmap_mat_scaled),
  if (!is.null(heatmap_annotation) && "run_id" %in% names(heatmap_annotation)) heatmap_annotation$run_id else colnames(heatmap_mat_scaled),
  colnames(heatmap_mat_scaled)
)
heatmap_mat_scaled <- heatmap_mat_scaled[, sample_order, drop = FALSE]
if (!is.null(heatmap_annotation)) {
  heatmap_annotation <- heatmap_annotation[sample_order, , drop = FALSE]
}

heatmap_row_order <- stats::hclust(stats::dist(heatmap_mat_scaled))$order
heatmap_col_order <- stats::hclust(stats::dist(t(heatmap_mat_scaled)))$order
heatmap_mat_clustered <- heatmap_mat_scaled[heatmap_row_order, heatmap_col_order, drop = FALSE]
if (!is.null(heatmap_annotation)) {
  heatmap_annotation <- heatmap_annotation[heatmap_col_order, , drop = FALSE]
}

interactive_heatmap_n <- min(100, nrow(heatmap_mat_clustered))
interactive_heatmap_mat <- heatmap_mat_clustered[seq_len(interactive_heatmap_n), , drop = FALSE]

dir.create("results/figures", recursive = TRUE, showWarnings = FALSE)
pheatmap::pheatmap(
  heatmap_mat_clustered,
  color = heatmap_palette,
  breaks = heatmap_breaks,
  cluster_rows = TRUE,
  cluster_cols = TRUE,
  show_rownames = FALSE,
  show_colnames = FALSE,
  annotation_col = heatmap_annotation,
  annotation_colors = if (!is.null(heatmap_annotation) && length(annotation_colors) == ncol(heatmap_annotation)) annotation_colors else NULL,
  main = "Top variable CpGs: unsupervised clustered heatmap",
  fontsize = 10,
  fontsize_col = 8,
  fontsize_row = 6,
  treeheight_row = 35,
  treeheight_col = 40,
  angle_col = 45,
  border_color = NA,
  legend = TRUE,
  annotation_legend = TRUE,
  cellwidth = NA,
  cellheight = 8,
  filename = "results/figures/all_samples_heatmap.png",
  width = 8.6,
  height = 9.5
)

write_table(
  tibble::tibble(cpg_id = rownames(heatmap_mat), variance = matrixStats::rowVars(heatmap_mat)),
  "results/tables/all_samples_heatmap_top_variable_cpgs.csv"
)

heatmap_hover <- matrix(
  "",
  nrow = nrow(interactive_heatmap_mat),
  ncol = ncol(interactive_heatmap_mat),
  dimnames = dimnames(interactive_heatmap_mat)
)
for (row_i in seq_len(nrow(interactive_heatmap_mat))) {
  cpg <- rownames(interactive_heatmap_mat)[row_i]
  for (col_i in seq_len(ncol(interactive_heatmap_mat))) {
    sid <- colnames(interactive_heatmap_mat)[col_i]
    meta_row <- meta[match(sid, meta$sample_id), , drop = FALSE]
    group_val <- if ("group" %in% names(meta_row)) as.character(meta_row$group[[1]]) else ""
    run_val <- if ("run_id" %in% names(meta_row)) as.character(meta_row$run_id[[1]]) else ""
    heatmap_hover[row_i, col_i] <- paste0(
      "Sample: ", sid,
      "<br>CpG: ", cpg,
      "<br>Group: ", group_val,
      "<br>Run: ", run_val,
      "<br>Scaled beta: ", sprintf("%.3f", interactive_heatmap_mat[row_i, col_i])
    )
  }
}

plotly_heatmap_widget <- plotly::plot_ly(
