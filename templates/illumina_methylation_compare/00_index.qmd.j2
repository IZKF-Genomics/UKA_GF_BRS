```{r setup, echo=TRUE, warning=FALSE, message=FALSE}
source("common.R")
ensure_dirs(".")
cfg <- load_config("config/project.toml")
if (!requireNamespace("plotly", quietly = TRUE)) log_error("Package 'plotly' is required")
if (!requireNamespace("htmlwidgets", quietly = TRUE)) log_error("Package 'htmlwidgets' is required")
if (!requireNamespace("uwot", quietly = TRUE)) log_error("Package 'uwot' is required")
if (!requireNamespace("Rtsne", quietly = TRUE)) log_error("Package 'Rtsne' is required")
samples <- load_samples("config/samples.csv")
gm <- load_group_map(coalesce_chr(cfg$input$group_map_file, "config/group_map.csv"))
samples <- apply_group_map(samples, gm, group_col = cfg$groups$primary_group_col)
comparisons <- resolve_enabled_comparisons(cfg, samples)
read_if <- function(path) if (file.exists(path)) readr::read_csv(path, show_col_types = FALSE) else NULL
run_summary <- read_if("results/tables/input_run_summary.csv")
dmp_summary <- read_if("results/tables/dmp_comparisons_summary.csv")

overview_tbl <- tibble::tibble(
  metric = c("project_name", "array_type", "genome_build", "input_registry_file", "group_map_file", "comparisons_file", "n_enabled_input_runs", "n_enabled_comparisons", "n_samples"),
  value = c(
    cfg$project$name,
    cfg$project$array_type,
    cfg$project$genome_build,
    cfg$input$input_registry_file,
    cfg$input$group_map_file,
    cfg$comparisons$comparisons_file,
    if (is.null(run_summary)) NA else nrow(run_summary),
    nrow(comparisons),
    nrow(samples)
  )
)
write_table(overview_tbl, "results/tables/overview_table.csv")
write_table(comparisons, "results/tables/enabled_comparisons.csv")

obj <- load_analysis_inputs(cfg, samples)
beta <- get_beta_matrix(obj)
pdata <- get_pdata(obj)
meta <- merge_input_metadata(beta, pdata, samples)

embedding_palette <- function(values) {
  vals <- sort(unique(as.character(stats::na.omit(values))))
  if (length(vals) == 0) return(character(0))
  stats::setNames(grDevices::hcl.colors(length(vals), "Dark 3"), vals)
}

theme_pub <- function() {
  ggplot2::theme_minimal(base_size = 13) +
    ggplot2::theme(
      plot.title = ggplot2::element_text(face = "bold", size = 16),
      plot.subtitle = ggplot2::element_text(color = "#4A4A4A"),
      axis.title = ggplot2::element_text(face = "bold"),
      panel.grid.minor = ggplot2::element_blank(),
      legend.position = "bottom",
      legend.title = ggplot2::element_text(face = "bold")
    )
}

build_embedding_plot <- function(df, x, y, color_var, title) {
  palette_vals <- embedding_palette(df[[color_var]])
  ggplot2::ggplot(df, ggplot2::aes(.data[[x]], .data[[y]], color = .data[[color_var]])) +
    ggplot2::geom_point(size = 3, alpha = 0.9) +
    ggplot2::scale_color_manual(values = palette_vals) +
    ggplot2::labs(
      title = title,
      subtitle = paste(nrow(df), "samples"),
      x = x,
      y = y,
      color = color_var
    ) +
    theme_pub()
}

embedding_hover_text <- function(df, axis_labels) {
  group_vals <- if ("group" %in% names(df)) as.character(df$group) else rep("", nrow(df))
  run_vals <- if ("run_id" %in% names(df)) as.character(df$run_id) else rep("", nrow(df))
  out <- paste0(
    "<b>", df$sample_id, "</b><br>",
    "Group: ", group_vals, "<br>",
    "Run: ", run_vals, "<br>",
    axis_labels[[1]], ": ", sprintf("%.3f", df[[axis_labels[[1]]]]), "<br>",
    axis_labels[[2]], ": ", sprintf("%.3f", df[[axis_labels[[2]]]])
  )
  if (length(axis_labels) >= 3) {
    out <- paste0(
      out,
      "<br>",
      axis_labels[[3]], ": ", sprintf("%.3f", df[[axis_labels[[3]]]])
    )
  }
  out
}

build_plotly_2d <- function(df, x, y, color_var, title) {
  palette_vals <- embedding_palette(df[[color_var]])
  df$hover_text <- embedding_hover_text(df, c(x, y))
  plotly::layout(
    plotly::plot_ly(
      data = df,
      x = stats::as.formula(paste0("~`", x, "`")),
      y = stats::as.formula(paste0("~`", y, "`")),
      type = "scatter",
      mode = "markers",
      color = stats::as.formula(paste0("~`", color_var, "`")),
      colors = unname(palette_vals),
      text = ~hover_text,
      hoverinfo = "text",
      marker = list(size = 8, opacity = 0.85)
    ),
    title = list(text = title),
    legend = list(orientation = "h", y = -0.2),
    xaxis = list(title = x),
    yaxis = list(title = y)
  )
}

build_plotly_3d <- function(df, x, y, z, color_var, title) {
  palette_vals <- embedding_palette(df[[color_var]])
  df$hover_text <- embedding_hover_text(df, c(x, y, z))
  plotly::layout(
    plotly::plot_ly(
      data = df,
      x = stats::as.formula(paste0("~`", x, "`")),
      y = stats::as.formula(paste0("~`", y, "`")),
      z = stats::as.formula(paste0("~`", z, "`")),
      type = "scatter3d",
      mode = "markers",
      color = stats::as.formula(paste0("~`", color_var, "`")),
      colors = unname(palette_vals),
      text = ~hover_text,
      hoverinfo = "text",
      marker = list(size = 4.5, opacity = 0.85)
    ),
    title = list(text = title),
    legend = list(orientation = "h", y = -0.15),
    scene = list(
      xaxis = list(title = x),
      yaxis = list(title = y),
      zaxis = list(title = z)
    )
  )
}

save_widget <- function(widget, path) {
  dir.create(dirname(path), recursive = TRUE, showWarnings = FALSE)
  htmlwidgets::saveWidget(widget, file = path, selfcontained = TRUE)
  invisible(path)
}

n_keep <- min(5000, nrow(beta))
var_idx <- order(matrixStats::rowVars(beta), decreasing = TRUE)
if (length(var_idx) > n_keep) var_idx <- var_idx[seq_len(n_keep)]
beta_var <- beta[var_idx, , drop = FALSE]
embedding_input <- t(beta_var)
sample_id_order <- rownames(embedding_input)

set.seed(42)
pc <- stats::prcomp(embedding_input, center = TRUE, scale. = FALSE)
pca_df <- tibble::as_tibble(pc$x[, 1:3, drop = FALSE])
pca_df$sample_id <- sample_id_order
pca_df <- dplyr::left_join(pca_df, meta, by = "sample_id")

n_samples <- nrow(embedding_input)
set.seed(42)
umap_coords <- uwot::umap(
  embedding_input,
  n_components = 3,
  n_neighbors = min(15, max(2, n_samples - 1)),
  min_dist = 0.2,
  metric = "euclidean",
  init = "spca",
  verbose = FALSE
)
colnames(umap_coords) <- c("UMAP1", "UMAP2", "UMAP3")
umap_df <- tibble::as_tibble(umap_coords)
umap_df$sample_id <- sample_id_order
umap_df <- dplyr::left_join(umap_df, meta, by = "sample_id")

tsne_perplexity <- min(30, max(1, floor((n_samples - 1) / 3)))
set.seed(42)
tsne_fit <- Rtsne::Rtsne(
  embedding_input,
  dims = 3,
  perplexity = tsne_perplexity,
  pca = TRUE,
  check_duplicates = FALSE,
  verbose = FALSE
)
colnames(tsne_fit$Y) <- c("TSNE1", "TSNE2", "TSNE3")
tsne_df <- tibble::as_tibble(tsne_fit$Y)
tsne_df$sample_id <- sample_id_order
tsne_df <- dplyr::left_join(tsne_df, meta, by = "sample_id")

group_col <- cfg$groups$primary_group_col

save_plot(
  build_embedding_plot(pca_df, "PC1", "PC2", group_col, "PCA: all samples"),
  "results/figures/all_samples_pca.png",
  width = 9,
  height = 6
)
save_plot(
  build_embedding_plot(umap_df, "UMAP1", "UMAP2", group_col, "UMAP: all samples"),
  "results/figures/all_samples_umap.png",
  width = 9,
  height = 6
)
save_plot(
  build_embedding_plot(tsne_df, "TSNE1", "TSNE2", group_col, "t-SNE: all samples"),
  "results/figures/all_samples_tsne.png",
  width = 9,
  height = 6
)

write_table(pca_df, "results/tables/all_samples_pca.csv")
write_table(umap_df, "results/tables/all_samples_umap.csv")
write_table(tsne_df, "results/tables/all_samples_tsne.csv")

pca_plotly_2d <- build_plotly_2d(pca_df, "PC1", "PC2", group_col, "PCA 2D")
pca_plotly_3d <- build_plotly_3d(pca_df, "PC1", "PC2", "PC3", group_col, "PCA 3D")
umap_plotly_2d <- build_plotly_2d(umap_df, "UMAP1", "UMAP2", group_col, "UMAP 2D")
umap_plotly_3d <- build_plotly_3d(umap_df, "UMAP1", "UMAP2", "UMAP3", group_col, "UMAP 3D")
tsne_plotly_2d <- build_plotly_2d(tsne_df, "TSNE1", "TSNE2", group_col, "t-SNE 2D")
tsne_plotly_3d <- build_plotly_3d(tsne_df, "TSNE1", "TSNE2", "TSNE3", group_col, "t-SNE 3D")

save_widget(pca_plotly_2d, "results/widgets/pca_2d.html")
save_widget(umap_plotly_2d, "results/widgets/umap_2d.html")
save_widget(tsne_plotly_2d, "results/widgets/tsne_2d.html")
save_widget(pca_plotly_3d, "results/widgets/pca_3d.html")
save_widget(umap_plotly_3d, "results/widgets/umap_3d.html")
save_widget(tsne_plotly_3d, "results/widgets/tsne_3d.html")
```

## Method

This report is the cohort-level overview for the combined methylation analysis. It loads the enabled upstream runs, harmonizes probe identifiers across array versions, restricts the analysis to probes shared by all enabled runs, and then merges the sample metadata and methylation matrices into one joint dataset.

The unsupervised visualizations are built from the merged matrix after selecting the most variable probes across all samples. PCA summarizes the dominant linear axes of variation, whereas UMAP and t-SNE provide nonlinear embeddings that help reveal local neighborhood structure and compact subgroups that may not be obvious in PCA alone.

The static figures are intended for manuscript-style viewing, while the interactive Plotly panels allow readers to inspect sample labels and rotate the three-dimensional embeddings. The coordinate tables and widget files shown in this report are written to the `results/` directory so they can be reused outside the HTML report.

