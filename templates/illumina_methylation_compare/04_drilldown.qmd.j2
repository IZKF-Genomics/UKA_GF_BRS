```{r setup, echo=TRUE, warning=FALSE, message=FALSE}
source("common.R")
ensure_dirs(".")
cfg <- load_config("config/project.toml")
samples <- load_samples("config/samples.csv")
if (!isTRUE(cfg$drilldown$enabled)) {
  cat("Drilldown disabled in config.\n")
  knitr::knit_exit()
}
obj <- load_analysis_inputs(cfg, samples)
beta <- get_beta_matrix(obj)
ann <- get_annotation_df(obj)
pdata <- get_pdata(obj)
dmp_by_cmp <- if (file.exists("results/rds/dmp_by_comparison.rds")) read_rds("results/rds/dmp_by_comparison.rds") else list()

ann2 <- ann
if (!("Name" %in% names(ann2))) ann2$Name <- rownames(beta)
pick_first_col <- function(df, candidates, default = NA) {
  for (nm in candidates) {
    if (nm %in% names(df)) return(df[[nm]])
  }
  rep(default, nrow(df))
}
ann2 <- dplyr::mutate(ann2, chr = as.character(pick_first_col(ann2, c("chr", "CHR"), NA_character_)))
ann2 <- dplyr::mutate(ann2, pos = suppressWarnings(as.numeric(pick_first_col(ann2, c("pos", "MAPINFO"), NA_real_))))

cpg_ids <- unlist(cfg$drilldown$cpg_ids)
loci <- unlist(cfg$drilldown$loci)
genes <- unlist(cfg$drilldown$genes)
write_table(tibble::tibble(cpg_ids = cpg_ids), "results/tables/drilldown_requested_cpg_ids.csv")
write_table(tibble::tibble(loci = loci), "results/tables/drilldown_requested_loci.csv")
write_table(tibble::tibble(genes = genes), "results/tables/drilldown_requested_genes.csv")

cpg_detail_tables <- list()
locus_detail_tables <- list()
gene_detail_tables <- list()
cpg_summary_rows <- list()
locus_summary_rows <- list()
gene_summary_rows <- list()

# CpG drilldowns over all samples
for (cpg in cpg_ids) {
  if (!(cpg %in% rownames(beta))) next
  df <- tibble::tibble(sample_id = colnames(beta), beta = as.numeric(beta[cpg, ]))
  if ("sample_id" %in% names(pdata)) df <- dplyr::left_join(df, tibble::as_tibble(pdata), by = "sample_id")
  for (cmp_id in names(dmp_by_cmp)) {
    dmp <- dmp_by_cmp[[cmp_id]]
    df[[paste0("in_dmp_", cmp_id)]] <- cpg %in% dmp$CpG
  }
  out_path <- file.path("results/tables", paste0("drilldown_cpg_", cpg, ".csv"))
  write_table(df, out_path)
  cpg_detail_tables[[cpg]] <- list(data = df, path = out_path)
  cpg_summary_rows[[cpg]] <- tibble::tibble(
    cpg_id = cpg,
    n_samples = nrow(df),
    mean_beta = mean(df$beta, na.rm = TRUE),
    sd_beta = stats::sd(df$beta, na.rm = TRUE),
    found_in_dmp = any(vapply(names(dmp_by_cmp), function(cmp_id) cpg %in% dmp_by_cmp[[cmp_id]]$CpG, logical(1)))
  )
}

# Locus drilldowns
for (loc in loci) {
  m <- stringr::str_match(loc, "^([^:]+):(\\d+)-(\\d+)$")
  if (any(is.na(m))) next
  chr <- m[,2]; start <- as.numeric(m[,3]); end <- as.numeric(m[,4])
  loc_tbl <- ann2 %>% dplyr::filter(.data$chr == chr, .data$pos >= start, .data$pos <= end)
  if (nrow(loc_tbl) > cfg$drilldown$max_cpgs_per_locus) loc_tbl <- dplyr::slice_head(loc_tbl, n = cfg$drilldown$max_cpgs_per_locus)
  tag <- gsub("[^A-Za-z0-9]+", "_", loc)
  out_path <- file.path("results/tables", paste0("drilldown_locus_", tag, ".csv"))
  write_table(loc_tbl, out_path)
  locus_detail_tables[[loc]] <- list(data = loc_tbl, path = out_path)
  locus_summary_rows[[loc]] <- tibble::tibble(
    locus = loc,
    n_matching_cpg = nrow(loc_tbl),
    chr = chr,
    start = start,
    end = end
  )
}

# Gene drilldowns
gene_cols <- intersect(c("UCSC_RefGene_Name", "GeneSymbol", "gene", "SYMBOL"), names(ann2))
for (gene in genes) {
  if (length(gene_cols) == 0) break
  gene_tbl <- ann2[Reduce(`|`, lapply(gene_cols, function(col) grepl(gene, ann2[[col]], fixed = TRUE))), , drop = FALSE]
  tag <- gsub("[^A-Za-z0-9]+", "_", gene)
  out_path <- file.path("results/tables", paste0("drilldown_gene_", tag, ".csv"))
  write_table(gene_tbl, out_path)
  gene_detail_tables[[gene]] <- list(data = gene_tbl, path = out_path)
  gene_summary_rows[[gene]] <- tibble::tibble(
    gene = gene,
    n_matching_cpg = nrow(gene_tbl),
    annotation_columns_used = paste(gene_cols, collapse = "; ")
  )
}

cpg_summary_tbl <- dplyr::bind_rows(cpg_summary_rows)
locus_summary_tbl <- dplyr::bind_rows(locus_summary_rows)
gene_summary_tbl <- dplyr::bind_rows(gene_summary_rows)
write_table(cpg_summary_tbl, "results/tables/drilldown_cpg_summary.csv")
write_table(locus_summary_tbl, "results/tables/drilldown_locus_summary.csv")
write_table(gene_summary_tbl, "results/tables/drilldown_gene_summary.csv")
```

## Method

This report is a targeted lookup layer over the combined methylation dataset. It uses the configured CpG IDs, genomic loci, and gene symbols from `project.toml` to extract matching probe annotations and sample-level beta values from the merged analysis object.

Requested CpG IDs are expanded into per-sample beta-value tables so readers can inspect the exact methylation values across the cohort. Requested loci are resolved by genomic overlap against the probe annotation, and requested genes are resolved through the available gene-annotation columns in the methylation manifest.

The drilldown outputs are intended for targeted follow-up rather than hypothesis testing. They provide convenient tables for export and manual review, including whether a requested CpG appeared in any of the comparison-specific DMP result tables already generated in this analysis.

## Requested CpG IDs

These are the exact CpG targets requested for direct drilldown and per-sample beta-value export.

```{r requested-cpgs}
render_report_table(tibble::tibble(cpg_ids = cpg_ids), page_length = 20)
report_download_link("results/tables/drilldown_requested_cpg_ids.csv")
```

## Requested Loci

These genomic loci are expanded into matching probe sets for targeted locus-level inspection.

```{r requested-loci}
render_report_table(tibble::tibble(loci = loci), page_length = 20)
report_download_link("results/tables/drilldown_requested_loci.csv")
```

## Requested Genes

These gene symbols are used to retrieve annotation-linked probes for targeted gene-centric review.

```{r requested-genes}
render_report_table(tibble::tibble(genes = genes), page_length = 20)
report_download_link("results/tables/drilldown_requested_genes.csv")
```

## CpG Drilldown Summary

This summary table reports whether each requested CpG was found in the combined methylation matrix and gives basic beta-value summary statistics across all samples.

```{r cpg-drilldown-summary}
render_report_table(
  cpg_summary_tbl,
  preferred = c("cpg_id", "n_samples", "mean_beta", "sd_beta", "found_in_dmp"),
  page_length = 20
)
report_download_link("results/tables/drilldown_cpg_summary.csv")
```

## CpG Drilldown Details

The following sections provide sample-level beta values for each requested CpG together with available sample metadata and flags indicating whether the CpG appears in any comparison-specific DMP result table.

```{r cpg-drilldown-details, results='asis'}
for (cpg in names(cpg_detail_tables)) {
  entry <- cpg_detail_tables[[cpg]]
  cat("### CpG: ", cpg, "\n\n", sep = "")
  cat("This table lists the per-sample beta values for the requested CpG across the merged cohort.\n\n")
  print(render_report_table(
    entry$data,
    preferred = c("sample_id", "beta", "group", "run_id", "dataset_id", "sex_reported", "age"),
    page_length = min(25, max(10, nrow(entry$data)))
  ))
  print(report_download_link(entry$path))
  cat("\n")
}
```

## Locus Drilldown Summary

This summary shows how many probes from the annotation fall into each requested genomic interval after optional truncation by the configured maximum CpGs per locus.

```{r locus-drilldown-summary}
render_report_table(
  locus_summary_tbl,
  preferred = c("locus", "n_matching_cpg", "chr", "start", "end"),
  page_length = 20
)
report_download_link("results/tables/drilldown_locus_summary.csv")
```

## Locus Drilldown Details

Each locus section lists the probes that overlap the requested interval, together with the available annotation columns carried through from the methylation manifest.

```{r locus-drilldown-details, results='asis'}
for (loc in names(locus_detail_tables)) {
  entry <- locus_detail_tables[[loc]]
  cat("### Locus: ", loc, "\n\n", sep = "")
  cat("These rows represent the CpGs whose annotated genomic coordinates overlap the requested locus.\n\n")
  print(render_report_table(
    entry$data,
    preferred = c("Name", "chr", "pos", "strand", "Relation_to_Island", "UCSC_RefGene_Name", "UCSC_RefGene_Group", "Regulatory_Feature_Group"),
    page_length = min(25, max(10, nrow(entry$data)))
  ))
  print(report_download_link(entry$path))
  cat("\n")
}
```

## Gene Drilldown Summary

This summary shows how many annotation-linked probes were retrieved for each requested gene symbol.

```{r gene-drilldown-summary}
render_report_table(
  gene_summary_tbl,
  preferred = c("gene", "n_matching_cpg", "annotation_columns_used"),
  page_length = 20
)
report_download_link("results/tables/drilldown_gene_summary.csv")
```

## Gene Drilldown Details

Each gene section lists the probes whose annotation contains the requested gene symbol in one of the supported manifest gene columns.

```{r gene-drilldown-details, results='asis'}
for (gene in names(gene_detail_tables)) {
  entry <- gene_detail_tables[[gene]]
  cat("### Gene: ", gene, "\n\n", sep = "")
  cat("These rows represent probes linked to the requested gene through the available manifest gene annotations.\n\n")
  print(render_report_table(
    entry$data,
    preferred = c("Name", "chr", "pos", "strand", "Relation_to_Island", "UCSC_RefGene_Name", "UCSC_RefGene_Group", "Regulatory_Feature_Group"),
    page_length = min(25, max(10, nrow(entry$data)))
  ))
  print(report_download_link(entry$path))
  cat("\n")
}
```
