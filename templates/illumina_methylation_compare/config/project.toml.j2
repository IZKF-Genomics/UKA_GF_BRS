[project]
name = "{{ ctx.params.study_name | default(ctx.template.id, true) }}"
array_type = "{{ ctx.params.array_type }}"    # "AUTO" | "450K" | "EPIC" | "EPIC_V2"
genome_build = "{{ ctx.params.genome_build }}"
outdir = "reports"

[input]
input_registry_file = "config/input_registry.csv"
group_map_file = "config/group_map.csv"
samples_file = "config/samples.csv"
samples_paths_file = "config/samples_paths.csv"
require_samples_in_sheet = false
sync_samples_on_run = true

[groups]
primary_group_col = "{{ ctx.params.group_col }}"

[comparisons]
comparisons_file = "config/comparisons.csv"

[batch]
enabled = false
method = "limma_removeBatchEffect"
batch_col = "run_id"
preserve_cols = ["{{ ctx.params.group_col }}"]

[dmp]
enabled = true
use_m_values = true
adjust_method = "BH"
alpha = 0.05
delta_beta_min = 0.10
covariates = []

[dmr]
enabled = true
method = "DMRcate"
alpha = 0.05
max_gap_bp = 1000
min_cpgs = 3
top_n_regions = 15
top_n_heatmap_regions = 12

[enrichment]
enabled = true
method = "missMethyl_gometh"
collections = ["GO", "KEGG"]
ontologies = ["BP", "MF", "CC"]
top_n = 30

[drilldown]
enabled = true
cpg_ids = ["cg00000029"]
loci = ["chr1:1000000-1010000"]
genes = ["BRCA1"]
max_cpgs_per_locus = 200
heatmap_top_var = 100
