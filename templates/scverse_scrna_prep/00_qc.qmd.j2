## Setup

```{python}
from pathlib import Path
import json
import math
import tomllib

import numpy as np
import pandas as pd
import scanpy as sc
from scipy import sparse
import plotly.express as px
import plotly.graph_objects as go
from plotly.subplots import make_subplots

ROOT = Path(".").resolve()
CONFIG_PATH = ROOT / "config" / "project.toml"

QC_PATTERNS = {
    "human": {
        "mt": ("MT-",),
        "ribo": ("RPS", "RPL"),
        "hb_regex": r"^HB(?!P)",
    },
    "mouse": {
        "mt": ("mt-", "mt."),
        "ribo": ("Rps", "Rpl"),
        "hb_regex": r"^Hb(?!p)",
    },
}

ORGANISM_ALIASES = {
    "human": "human",
    "hsapiens": "human",
    "homo_sapiens": "human",
    "mouse": "mouse",
    "mmusculus": "mouse",
    "mus_musculus": "mouse",
}

STAGE_ORDER = ["Before filtering", "After filtering"]
STAGE_COLORS = {
    "Before filtering": "#68737d",
    "After filtering": "#0f766e",
}
QUALITATIVE_SEQUENCE = ["#0f766e", "#7c3aed", "#d97706", "#dc2626", "#2563eb", "#059669", "#b91c1c", "#475569"]


def load_config(path: Path) -> dict:
    with path.open("rb") as fh:
        return tomllib.load(fh)


def ensure_parent(path: Path) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)


def resolve_path(root: Path, value: str) -> Path:
    p = Path(value)
    return p if p.is_absolute() else (root / p).resolve()


def detect_input_format(path: Path) -> str:
    if path.is_dir():
        return "10x_mtx"
    lower = path.name.lower()
    if lower.endswith(".h5ad"):
        return "h5ad"
    if lower.endswith(".h5"):
        return "10x_h5"
    return ""


def read_optional_metadata(path: Path) -> pd.DataFrame | None:
    if not path.exists() or path.stat().st_size == 0:
        return None
    df = pd.read_csv(path)
    return None if df.empty else df


def sparse_copy(x):
    return x.copy() if sparse.issparse(x) else np.array(x, copy=True)


def infer_sample_id(obs: pd.DataFrame, preferred_key: str) -> pd.Series:
    candidates = [preferred_key, "sample_id", "sample", "orig.ident", "library_id", "batch"]
    for key in candidates:
        if key in obs.columns:
            vals = obs[key].astype(str).fillna("unknown")
            if vals.nunique() > 0:
                return vals
    return pd.Series(["sample1"] * obs.shape[0], index=obs.index, dtype="object")


def annotate_qc_genes(adata, organism: str) -> None:
    org = ORGANISM_ALIASES.get(organism.lower(), "")
    if org not in QC_PATTERNS:
        raise RuntimeError(
            "metadata.organism is missing or unsupported. Set --param organism or ensure an upstream template wrote params.organism in project.yaml."
        )
    pats = QC_PATTERNS[org]
    var_names = pd.Index(adata.var_names.astype(str))
    adata.var["mt"] = var_names.str.startswith(pats["mt"])
    adata.var["ribo"] = var_names.str.startswith(pats["ribo"])
    adata.var["hb"] = var_names.str.match(pats["hb_regex"], case=False)


def apply_sample_metadata(adata, metadata_df: pd.DataFrame, sample_id_key: str) -> None:
    if "sample_id" not in metadata_df.columns:
        raise RuntimeError("sample metadata must contain a sample_id column")

    adata.obs[sample_id_key] = adata.obs[sample_id_key].astype(str)
    meta = metadata_df.copy()
    meta["sample_id"] = meta["sample_id"].astype(str)
    joined = adata.obs.merge(meta, how="left", left_on=sample_id_key, right_on="sample_id", suffixes=("", "_meta"))
    joined.index = adata.obs.index

    for col in meta.columns:
        if col == "sample_id":
            continue
        meta_col = f"{col}_meta"
        if meta_col in joined.columns:
            existing = joined[col] if col in joined.columns else pd.Series(index=joined.index, dtype="object")
            joined[col] = joined[meta_col].combine_first(existing)
            joined = joined.drop(columns=[meta_col])

    adata.obs = joined


def write_json(path: Path, data: dict) -> None:
    ensure_parent(path)
    path.write_text(json.dumps(data, indent=2), encoding="utf-8")


def resolve_leiden_resolution(raw_value: str, n_cells: int) -> tuple[float, str]:
    value = str(raw_value).strip()
    if value:
        return float(value), "manual"
    if n_cells < 2000:
        return 0.4, "auto"
    if n_cells < 10000:
        return 0.6, "auto"
    if n_cells < 50000:
        return 0.8, "auto"
    return 1.0, "auto"


def load_input_adata(input_h5ad: str, input_matrix: str, input_format: str):
    chosen = ""
    if str(input_matrix).strip():
        chosen = str(input_matrix).strip()
    elif str(input_h5ad).strip():
        chosen = str(input_h5ad).strip()
    else:
        raise RuntimeError(
            "No input matrix was provided. Set input_matrix/input_h5ad or render in a project with nfcore_scrnaseq published outputs."
        )

    input_path = resolve_path(ROOT, chosen)
    fmt = str(input_format).strip().lower() or "auto"
    if fmt == "auto":
        fmt = detect_input_format(input_path)
    if fmt not in {"h5ad", "10x_h5", "10x_mtx"}:
        raise RuntimeError(
            f"Could not determine input format for '{input_path}'. Set input_format to one of: h5ad, 10x_h5, 10x_mtx."
        )

    if fmt == "h5ad":
        adata = sc.read_h5ad(input_path)
    elif fmt == "10x_h5":
        adata = sc.read_10x_h5(input_path)
    else:
        adata = sc.read_10x_mtx(input_path, var_names="gene_symbols", make_unique=True)

    return adata, input_path, fmt


def metric_summary(df: pd.DataFrame, stage: str, metric: str) -> dict[str, float | str]:
    series = df[metric].dropna()
    q1 = float(series.quantile(0.25)) if not series.empty else math.nan
    q3 = float(series.quantile(0.75)) if not series.empty else math.nan
    return {
        "stage": stage,
        "metric": metric,
        "n_cells": int(df.shape[0]),
        "median": float(series.median()) if not series.empty else math.nan,
        "mean": float(series.mean()) if not series.empty else math.nan,
        "q1": q1,
        "q3": q3,
        "iqr": q3 - q1 if not math.isnan(q1) and not math.isnan(q3) else math.nan,
    }


def compare_metric_figure(long_df: pd.DataFrame, metric: str, label: str) -> go.Figure:
    plot_df = long_df[["stage", metric, "sample_id"]].dropna().copy()
    plot_df["stage"] = pd.Categorical(plot_df["stage"], categories=STAGE_ORDER, ordered=True)
    fig = make_subplots(
        rows=1,
        cols=2,
        subplot_titles=(f"{label}: histogram", f"{label}: violin"),
        horizontal_spacing=0.12,
    )
    for idx, stage in enumerate(STAGE_ORDER, start=1):
        stage_df = plot_df[plot_df["stage"] == stage]
        fig.add_trace(
            go.Histogram(
                x=stage_df[metric],
                name=stage,
                marker=dict(color=STAGE_COLORS[stage]),
                opacity=0.75,
                nbinsx=60,
                legendgroup=stage,
                showlegend=(idx == 1),
            ),
            row=1,
            col=1,
        )
        fig.add_trace(
            go.Violin(
                y=stage_df[metric],
                x=[stage] * len(stage_df),
                name=stage,
                legendgroup=stage,
                marker=dict(color=STAGE_COLORS[stage]),
                line=dict(color=STAGE_COLORS[stage]),
                box_visible=True,
                meanline_visible=True,
                points="outliers",
                showlegend=False,
            ),
            row=1,
            col=2,
        )
    fig.update_layout(
        template="simple_white",
        barmode="overlay",
        height=420,
        title=f"{label}: before vs after filtering",
        legend=dict(orientation="h", y=1.12, x=0),
        font=dict(size=14),
        margin=dict(l=40, r=30, t=80, b=40),
    )
    fig.update_xaxes(title_text=label, row=1, col=1)
    fig.update_yaxes(title_text="Cell count", row=1, col=1)
    fig.update_xaxes(title_text="", row=1, col=2, categoryorder="array", categoryarray=STAGE_ORDER)
    fig.update_yaxes(title_text=label, row=1, col=2)
    return fig


def compare_sample_metric(sample_compare_df: pd.DataFrame, metric: str, label: str) -> go.Figure:
    fig = go.Figure()
    for stage in STAGE_ORDER:
        sub = sample_compare_df[sample_compare_df["stage"] == stage]
        fig.add_trace(
            go.Box(
                y=sub[metric],
                x=sub["stage"],
                name=stage,
                marker_color=STAGE_COLORS[stage],
                boxmean=True,
                boxpoints="outliers",
                jitter=0.25,
            )
        )
    fig.update_layout(
        template="simple_white",
        height=420,
        title=f"{label}: sample-level before vs after filtering",
        font=dict(size=14),
        margin=dict(l=40, r=30, t=80, b=40),
        showlegend=False,
    )
    fig.update_xaxes(categoryorder="array", categoryarray=STAGE_ORDER, title_text="")
    fig.update_yaxes(title_text=label)
    return fig


def embedding_plot(adata, color_key: str, title: str) -> go.Figure:
    coords = adata.obsm["X_umap"]
    emb = pd.DataFrame(coords, columns=["UMAP1", "UMAP2"], index=adata.obs_names)
    emb = emb.join(adata.obs[[color_key, "sample_id"]], how="left")
    emb[color_key] = emb[color_key].astype(str)
    emb["hover"] = (
        "cell="
        + emb.index.astype(str)
        + "<br>sample_id="
        + emb["sample_id"].astype(str)
        + f"<br>{color_key}="
        + emb[color_key].astype(str)
    )
    fig = px.scatter(
        emb,
        x="UMAP1",
        y="UMAP2",
        color=color_key,
        hover_name="sample_id",
        hover_data={"UMAP1": ":.3f", "UMAP2": ":.3f", color_key: True, "sample_id": False},
        template="simple_white",
        title=title,
        opacity=0.8,
        color_discrete_sequence=QUALITATIVE_SEQUENCE,
    )
    fig.update_traces(marker=dict(size=5), selector=dict(mode="markers"))
    fig.update_layout(height=560, font=dict(size=14), legend=dict(orientation="h"))
    return fig


def pca_plot(adata, color_key: str, title: str) -> go.Figure:
    coords = adata.obsm["X_pca"][:, :2]
    emb = pd.DataFrame(coords, columns=["PC1", "PC2"], index=adata.obs_names)
    emb = emb.join(adata.obs[[color_key, "sample_id"]], how="left")
    emb[color_key] = emb[color_key].astype(str)
    fig = px.scatter(
        emb,
        x="PC1",
        y="PC2",
        color=color_key,
        hover_name="sample_id",
        hover_data={"PC1": ":.3f", "PC2": ":.3f", color_key: True, "sample_id": False},
        template="simple_white",
        title=title,
        opacity=0.8,
        color_discrete_sequence=QUALITATIVE_SEQUENCE,
    )
    fig.update_traces(marker=dict(size=5), selector=dict(mode="markers"))
    fig.update_layout(height=560, font=dict(size=14), legend=dict(orientation="h"))
    return fig


def format_table(df: pd.DataFrame, digits: int = 3):
    out = df.copy()

    def _fmt_text(value):
        if pd.isna(value):
            return ""
        return str(value)

    def _fmt_int(value):
        if pd.isna(value):
            return ""
        return f"{int(round(float(value))):,}"

    def _fmt_float(value):
        if pd.isna(value):
            return ""
        return f"{float(value):,.{digits}f}"

    def _fmt_fraction(value):
        if pd.isna(value):
            return ""
        return f"{100 * float(value):.{max(1, digits - 1)}f}%"

    formatters = {}
    for col in out.columns:
        lower = str(col).lower()
        series = out[col]
        if pd.api.types.is_integer_dtype(series):
            formatters[col] = _fmt_int
        elif pd.api.types.is_float_dtype(series):
            if "fraction" in lower or lower.startswith("pct_") or lower.endswith("_pct"):
                formatters[col] = _fmt_fraction
            elif "n_" in lower or lower.endswith("_count") or lower.endswith("_counts") or lower.endswith("_cells") or lower.endswith("_genes"):
                formatters[col] = _fmt_int
            else:
                formatters[col] = _fmt_float
        else:
            formatters[col] = _fmt_text

    return (
        out.style
        .format(formatters)
        .set_properties(**{"text-align": "left", "white-space": "nowrap"})
        .set_table_styles(
            [
                {"selector": "th", "props": [("text-align", "left"), ("font-weight", "600")]},
                {"selector": "td", "props": [("padding", "0.25rem 0.5rem")]},
                {"selector": "table", "props": [("font-size", "0.95rem")]},
            ]
        )
    )


