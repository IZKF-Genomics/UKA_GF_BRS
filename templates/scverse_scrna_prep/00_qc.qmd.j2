```{python}
from pathlib import Path
import json
import pandas as pd

root = Path(".")
qc_summary = pd.read_csv(root / "results" / "tables" / "qc_summary.csv")
sample_qc = pd.read_csv(root / "results" / "tables" / "sample_qc_summary.csv")
cluster_counts = pd.read_csv(root / "results" / "tables" / "cluster_counts.csv")
run_summary = json.loads((root / "results" / "tables" / "run_summary.json").read_text())
qc_summary
```

