## QC Metrics

```{python}
annotate_qc_genes(adata, organism)
sc.pp.calculate_qc_metrics(adata, qc_vars=["mt", "ribo", "hb"], inplace=True)

min_genes = int(cfg["qc"]["min_genes"])
min_cells = int(cfg["qc"]["min_cells"])
min_counts = int(cfg["qc"]["min_counts"])
max_pct_counts_mt = float(cfg["qc"]["max_pct_counts_mt"])

adata.obs["pass_qc"] = (
    (adata.obs["n_genes_by_counts"] >= min_genes)
    & (adata.obs["total_counts"] >= min_counts)
    & (adata.obs["pct_counts_mt"] <= max_pct_counts_mt)
)

before_obs = adata.obs.copy()
before_obs["stage"] = "Before filtering"

qc_before = {
    "n_cells_before": int(adata.n_obs),
    "n_genes_before": int(adata.n_vars),
    "median_counts_before": float(np.median(before_obs["total_counts"])),
    "median_genes_before": float(np.median(before_obs["n_genes_by_counts"])),
    "median_pct_counts_mt_before": float(np.median(before_obs["pct_counts_mt"])),
}

qc_cell_df = before_obs.loc[
    :,
    ["sample_id", batch_key, condition_key, "total_counts", "n_genes_by_counts", "pct_counts_mt", "pass_qc", "stage"],
].copy()
qc_cell_df.to_csv(tables_dir / "cell_qc_metrics.csv", index=True)

before_sample_qc = (
    before_obs.groupby("sample_id", dropna=False)
    .agg(
        n_cells=("pass_qc", "size"),
        n_cells_pass_qc=("pass_qc", "sum"),
        median_total_counts=("total_counts", "median"),
        median_n_genes=("n_genes_by_counts", "median"),
        median_pct_counts_mt=("pct_counts_mt", "median"),
    )
    .reset_index()
)
before_sample_qc["retained_fraction"] = before_sample_qc["n_cells_pass_qc"] / before_sample_qc["n_cells"]

