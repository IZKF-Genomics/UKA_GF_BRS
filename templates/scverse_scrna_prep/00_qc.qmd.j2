ensure_parent(sample_qc_summary_file)
sample_compare_df.to_csv(sample_qc_summary_file, index=False)

before_after_stats.to_csv(tables_dir / "qc_metric_stage_summary.csv", index=False)
pd.DataFrame(comparison_rows).to_csv(tables_dir / "qc_metric_before_after.csv", index=False)
filter_effect_df.to_csv(tables_dir / "filter_effect_summary.csv", index=False)

filtered.uns["prep_config"] = cfg
filtered.uns["input_h5ad"] = str(input_path)
filtered.uns["resolved_leiden_resolution"] = resolved_leiden_resolution
filtered.uns["resolved_leiden_resolution_source"] = leiden_resolution_source
ensure_parent(out_adata)
filtered.write_h5ad(out_adata)

run_summary = {
    "project_name": cfg["project"]["name"],
    "organism": organism,
    "input_format": resolved_input_format,
    "batch_key": batch_key,
    "condition_key": condition_key,
    "leiden_resolution": resolved_leiden_resolution,
    "leiden_resolution_source": leiden_resolution_source,
    "output_h5ad": str(out_adata),
}
write_json(tables_dir / "run_summary.json", run_summary)

long_qc_df = pd.concat(
    [
        before_obs.assign(stage="Before filtering"),
        after_obs.assign(stage="After filtering"),
    ],
    axis=0,
    join="outer",
).reset_index(names="cell_id")
long_qc_df["stage"] = pd.Categorical(long_qc_df["stage"], categories=STAGE_ORDER, ordered=True)

sample_compare_long = pd.concat(
    [
        before_sample_qc.assign(stage="Before filtering", n_cells_stage=before_sample_qc["n_cells"], median_total_counts_stage=before_sample_qc["median_total_counts"], median_n_genes_stage=before_sample_qc["median_n_genes"], median_pct_counts_mt_stage=before_sample_qc["median_pct_counts_mt"]),
        sample_compare_df.assign(stage="After filtering", n_cells_stage=sample_compare_df["n_cells_after"], median_total_counts_stage=sample_compare_df["median_total_counts_after"], median_n_genes_stage=sample_compare_df["median_n_genes_after"], median_pct_counts_mt_stage=sample_compare_df["median_pct_counts_mt_after"]),
    ],
    ignore_index=True,
)

qc_summary
