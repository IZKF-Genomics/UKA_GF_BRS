#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$ROOT_DIR"

if [[ ! -f pixi.toml ]]; then
  echo "ERROR: missing required file: pixi.toml" >&2
  exit 1
fi
if [[ ! -f config/project.toml ]]; then
  echo "ERROR: missing required file: config/project.toml" >&2
  exit 1
fi
if [[ ! -f scripts/run_prep.py ]]; then
  echo "ERROR: missing required file: scripts/run_prep.py" >&2
  exit 1
fi
if ! command -v pixi >/dev/null 2>&1; then
  echo "ERROR: pixi not found on PATH" >&2
  exit 1
fi

echo "[INFO] Running scverse_scrna_prep for {{ ctx.project.name if ctx.project else ctx.template.id }}"
echo "[INFO] Root: $ROOT_DIR"

echo "[INFO] Installing/updating pixi environment"
pixi install

echo "[INFO] Validating Python entrypoint"
pixi run check

echo "[INFO] Running Scanpy preprocessing"
pixi run run-analysis

mkdir -p reports

echo "[INFO] Rendering 00_qc.qmd"
pixi run render

echo "[INFO] Complete. Results written to results/ and reports/"
