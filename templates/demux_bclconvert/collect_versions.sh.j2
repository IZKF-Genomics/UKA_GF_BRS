#!/usr/bin/env bash
set -euo pipefail

capture_version() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "not_found"
    return 0
  fi
  local raw
  raw="$("$@" 2>&1 | head -n 1 | tr -d '\r')" || raw="unknown"
  if [[ -z "$raw" ]]; then
    raw="unknown"
  fi
  echo "$raw"
}

yaml_escape() {
  printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'
}

echo "versions:"
echo "  bcl-convert: \"$(yaml_escape "$(capture_version bcl-convert bcl-convert --version)")\""
echo "  fastqc: \"$(yaml_escape "$(capture_version fastqc fastqc --version)")\""
echo "  fastq_screen: \"$(yaml_escape "$(capture_version fastq_screen fastq_screen --version)")\""
echo "  multiqc: \"$(yaml_escape "$(capture_version multiqc multiqc --version)")\""
echo "software_version_sources:"
echo "  - \"bcl-convert --version\""
echo "  - \"fastqc --version\""
echo "  - \"fastq_screen --version\""
echo "  - \"multiqc --version\""
