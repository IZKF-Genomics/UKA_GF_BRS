load_detail <- load_detail %>%
  dplyr::mutate(
    idat_pair_ok = red_exists & grn_exists,
    group = dplyr::coalesce(.data[[group_col]], .data[[paste0(group_col, "_meta")]])
  ) %>%
  dplyr::select(
    sample_id,
    group,
    dplyr::any_of(c("SentrixBarcode", "SentrixPosition")),
    red_exists,
    grn_exists,
    idat_pair_ok
  )

pretty_table(load_detail, caption = "Loaded samples with group and IDAT status")
write_table(load_detail, "results/tables/load_detail.csv")
```

## 2. QC

This section screens sample-level technical quality using detection p-values and intensity summaries.
Samples with high failed-probe fraction (above the red threshold line) should be reviewed before downstream interpretation.

```{r qc_compute_metrics}
detp <- get_detp(rgset)
qc_metrics <- tibble::tibble(
  sample_id = colnames(detp),
  mean_detp = colMeans(detp, na.rm = TRUE),
  frac_failed = colMeans(detp > cfg$qc$detection_p_threshold, na.rm = TRUE)
)
write_table(qc_metrics, "results/tables/qc_metrics.csv")
save_rds(list(detp = detp, qc_metrics = qc_metrics), "results/rds/qc.rds")
pretty_table(qc_metrics, caption = "Detection p-value QC metrics")
```

```{r qc_plot_failed_fraction}
n_samples_qc <- nrow(qc_metrics)
qc_plot_height <- max(5, min(20, 2 + 0.22 * n_samples_qc))
knitr::opts_current$set(fig.height = qc_plot_height)

p <- ggplot(qc_metrics, aes(x = reorder(sample_id, frac_failed), y = frac_failed)) +
  geom_col(fill = publication_palette[1], alpha = 0.9) +
  geom_hline(yintercept = cfg$qc$max_failed_probes_fraction, linetype = 2, color = publication_palette[2], linewidth = 0.6) +
  coord_flip() +
  labs(
    x = "Sample",
    y = "Fraction failed probes",
    title = "Detection p-value failure fraction per sample"
  ) +
  theme_publication()
print(p)
save_plot(p, "results/figures/qc_failed_fraction.png", width = 9, height = qc_plot_height)
```

```{r qc_table_intensity_summary}
if (requireNamespace("minfi", quietly = TRUE)) {
  int_df <- tryCatch({
    red <- minfi::getRed(rgset)
    grn <- minfi::getGreen(rgset)
    tibble::tibble(
      sample_id = colnames(rgset),
