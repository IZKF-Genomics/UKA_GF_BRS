## 6. Clustering

This section performs unsupervised sample similarity analysis using top variable CpGs.
Consistent PCA/UMAP neighborhood patterns support robust subtype structure; isolated points can indicate outliers or rare biology.

```{r cluster_compute_embeddings}
obj <- load_analysis_inputs()
beta <- get_beta_matrix(obj)
top_n <- as.integer(cfg$clustering$top_variable_cpg)
beta_top <- safe_top_var_rows(beta, n = top_n)
pca <- prcomp(t(beta_top), center = TRUE, scale. = FALSE)
pca_df <- tibble::as_tibble(pca$x[, 1:3], rownames = "sample_id")
pca_df <- dplyr::left_join(
  pca_df,
  tibble::as_tibble(samples) %>% dplyr::select(sample_id, dplyr::all_of(cfg$groups$primary_group_col)),
  by = "sample_id"
)
if (!(cfg$groups$primary_group_col %in% names(pca_df))) {
  gx <- paste0(cfg$groups$primary_group_col, ".x")
  gy <- paste0(cfg$groups$primary_group_col, ".y")
  if (gx %in% names(pca_df) && gy %in% names(pca_df)) {
    pca_df[[cfg$groups$primary_group_col]] <- dplyr::coalesce(pca_df[[gx]], pca_df[[gy]])
  } else if (gx %in% names(pca_df)) {
    pca_df[[cfg$groups$primary_group_col]] <- pca_df[[gx]]
  } else if (gy %in% names(pca_df)) {
    pca_df[[cfg$groups$primary_group_col]] <- pca_df[[gy]]
  }
}
if (requireNamespace("umap", quietly = TRUE) && ("umap" %in% unlist(cfg$clustering$methods))) {
  n_samples <- ncol(beta_top)
  if (n_samples >= 3) {
    umap_cfg <- umap::umap.defaults
    umap_cfg$n_neighbors <- min(umap_cfg$n_neighbors, n_samples - 1)
    um <- umap::umap(t(beta_top), config = umap_cfg)
    umap_df <- tibble::tibble(sample_id = colnames(beta_top), UMAP1 = um$layout[,1], UMAP2 = um$layout[,2])
  } else {
    umap_df <- tibble::tibble()
  }
} else {
  umap_df <- tibble::tibble()
}
if (nrow(umap_df) > 0) {
  umap_df <- dplyr::left_join(
    umap_df,
    tibble::as_tibble(samples) %>% dplyr::select(sample_id, dplyr::all_of(cfg$groups$primary_group_col)),
    by = "sample_id"
  )
}
if (requireNamespace("Rtsne", quietly = TRUE) && ("tsne" %in% unlist(cfg$clustering$methods))) {
  n_samples <- ncol(beta_top)
  if (n_samples >= 4) {
    perp <- min(30, floor((n_samples - 1) / 3))
    perp <- max(2, perp)
    ts <- Rtsne::Rtsne(t(beta_top), dims = 2, perplexity = perp, pca = TRUE, check_duplicates = FALSE)
    tsne_df <- tibble::tibble(sample_id = colnames(beta_top), TSNE1 = ts$Y[, 1], TSNE2 = ts$Y[, 2])
  } else {
    tsne_df <- tibble::tibble()
  }
} else {
  tsne_df <- tibble::tibble()
}
if (nrow(tsne_df) > 0) {
  tsne_df <- dplyr::left_join(
    tsne_df,
    tibble::as_tibble(samples) %>% dplyr::select(sample_id, dplyr::all_of(cfg$groups$primary_group_col)),
    by = "sample_id"
  )
}
d <- stats::dist(t(beta_top))
hc <- hclust(d)
clusters <- tibble::tibble(sample_id = hc$labels, hclust_order = match(hc$labels, hc$labels[hc$order]))
write_table(clusters, "results/tables/sample_clusters.csv")
save_rds(list(pca = pca, hc = hc, dist = d), "results/rds/clustering.rds")
```

