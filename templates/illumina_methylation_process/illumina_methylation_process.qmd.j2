```{r load_table_sample_idat_detail}
group_col <- cfg$groups$primary_group_col
sample_meta <- tibble::as_tibble(samples) %>%
  dplyr::select(sample_id, dplyr::all_of(group_col))

load_detail <- samples_resolved %>%
  dplyr::left_join(sample_meta, by = "sample_id", suffix = c("", "_meta")) %>%
  dplyr::left_join(
