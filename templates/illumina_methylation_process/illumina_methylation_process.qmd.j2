  write_table(int_df, "results/tables/qc_intensity_medians.csv")
}
```

## 3. Normalize

This section applies the configured normalization method and checks whether beta-value distributions are comparable across samples.
After successful normalization, density curves should have broadly similar shapes without obvious technical separation.

```{r normalize_apply_method}
method <- cfg$normalization$method
normset <- switch(
  method,
  noob = minfi::preprocessNoob(rgset),
  quantile = minfi::preprocessQuantile(rgset),
  swan = {
    mset_raw <- minfi::preprocessRaw(rgset)
    minfi::preprocessSwan(rgset, mset = mset_raw)
  },
  funnorm = minfi::preprocessFunnorm(rgset),
  log_error("Unsupported normalization method: ", method)
)
save_rds(normset, "results/rds/normset.rds")
summary_tbl <- tibble::tibble(metric = c("method", "n_samples", "n_probes"), value = c(method, ncol(normset), nrow(normset)))
write_table(summary_tbl, "results/tables/normalization_summary.csv")
pretty_table(summary_tbl, caption = "Normalization summary")
```

```{r normalize_plot_beta_density}
beta <- get_beta_matrix(normset)
dens_df <- as.data.frame(beta)
dens_long <- tidyr::pivot_longer(tibble::rownames_to_column(dens_df, "probe"), -probe, names_to = "sample_id", values_to = "beta")
dens_long <- dplyr::left_join(
  dens_long,
  tibble::as_tibble(samples) %>% dplyr::select(sample_id, dplyr::all_of(cfg$groups$primary_group_col)),
  by = "sample_id"
)
p <- ggplot(dens_long, aes(beta, group = sample_id, color = .data[[cfg$groups$primary_group_col]])) +
  geom_density(alpha = 0.35, linewidth = 0.5) +
  labs(
    title = paste("Beta density:", method),
    x = "Beta value",
    y = "Density",
    color = "group"
  ) +
  scale_color_publication() +
  theme_publication()
print(p)
save_plot(p, "results/figures/normalize_beta_density.png", width = 9, height = 5)
```

## 4. Filter

This section removes low-confidence or unwanted probes according to the project filter settings.
Interpret the summary as a probe-retention audit: high probe retention with expected removals indicates stable preprocessing.

```{r filter_apply_and_summarize}
qc <- read_rds("results/rds/qc.rds")
detp <- qc$detp
probe_ids <- NULL
if (methods::hasMethod("featureNames", class(normset))) {
  probe_ids <- Biobase::featureNames(normset)
}
if (is.null(probe_ids) || length(probe_ids) == 0) probe_ids <- rownames(normset)
if (is.null(probe_ids) || length(probe_ids) == 0) probe_ids <- rownames(detp)
keep <- rep(TRUE, length(probe_ids))
names(keep) <- probe_ids
removed <- list()
if (isTRUE(cfg$filter$remove_detection_fail)) {
  fail_any <- rowMeans(detp > cfg$qc$detection_p_threshold, na.rm = TRUE) > 0
  removed$detection_fail <- sum(fail_any)
  keep[names(fail_any)] <- keep[names(fail_any)] & !fail_any
} else {
  removed$detection_fail <- 0
}
ann <- get_annotation_df(normset)
if (isTRUE(cfg$filter$remove_sex_chr) || isTRUE(cfg$filter$keep_autosomal_only)) {
  chr_col <- intersect(c("chr", "CHR"), names(ann))[1]
  if (!is.na(chr_col) && !is.null(chr_col)) {
    sex_names <- ann %>% dplyr::filter(.data[[chr_col]] %in% c("chrX", "chrY", "X", "Y")) %>% dplyr::pull(.data$Name)
    sex_hit <- intersect(names(keep), sex_names)
    keep[sex_hit] <- FALSE
    removed$sex_chr <- length(sex_hit)
  } else {
    log_warn("Sex chromosome filtering requested but annotation chromosome column was not found")
    removed$sex_chr <- 0
  }
} else {
  removed$sex_chr <- 0
}
removed$snps <- 0
removed$cross_reactive <- 0
filteredset <- normset[keep, ]
save_rds(filteredset, "results/rds/filteredset.rds")
probes_in <- length(probe_ids)
probes_kept <- sum(keep, na.rm = TRUE)
filter_summary <- tibble::tibble(metric = c("probes_in", "probes_kept", "probes_removed_total"), value = c(probes_in, probes_kept, probes_in - probes_kept))
removed_tbl <- tibble::enframe(removed, name = "reason", value = "n_removed")
write_table(filter_summary, "results/tables/filter_summary.csv")
write_table(removed_tbl, "results/tables/probes_removed.csv")
pretty_table(filter_summary, caption = "Filter summary")
pretty_table(removed_tbl, caption = "Removed probes by reason")
```

## 5. Batch / Cell

This section provides an exploratory PCA view to detect potential structure from biology or technical effects.
When coloring by `group`, look for coherent within-group clustering and possible outliers.

```{r batch_prepare_pca}
obj <- read_rds("results/rds/filteredset.rds")
pdata <- get_pdata(obj)
beta <- get_beta_matrix(obj)
if (!("sample_id" %in% names(pdata))) {
  pdata$sample_id <- map_sample_id(colnames(beta))
} else {
  pdata$sample_id <- map_sample_id(pdata$sample_id)
}
pc <- prcomp(t(beta), center = TRUE, scale. = FALSE)
pc_df <- tibble::as_tibble(pc$x[, 1:2], rownames = "sample_col")
pc_df$sample_col <- colnames(beta)
if ("sample_id" %in% names(pdata)) {
  pc_df <- dplyr::left_join(pc_df, tibble::as_tibble(pdata), by = c("sample_col" = "sample_id"))
}
adjustedset <- obj
save_rds(adjustedset, "results/rds/adjustedset.rds")
write_table(tibble::tibble(note = c("No adjustment applied in scaffold by default")), "results/tables/batch_summary.csv")
if (isTRUE(cfg$cell_counts$enabled)) {
  write_table(tibble::tibble(note = "Cell count estimation enabled in config but not implemented in scaffold"), "results/tables/cell_counts.csv")
}
```

```{r batch_plot_pca_group}
col_group <- if (cfg$groups$primary_group_col %in% names(pc_df)) cfg$groups$primary_group_col else NULL
pdata_meta <- tibble::as_tibble(samples) %>% dplyr::select(sample_id, dplyr::all_of(cfg$groups$primary_group_col))
pc_df_plot <- dplyr::left_join(pc_df, pdata_meta, by = c("sample_col" = "sample_id"))
