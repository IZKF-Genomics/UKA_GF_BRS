```{r setup}
source("common.R")
ensure_dirs(".")
cfg <- load_config("project.toml")
samples <- load_samples("samples.csv")
```

## 1. Load IDAT

This section validates sample metadata, resolves IDAT basenames, and imports raw methylation signals.
Use these tables to confirm that all expected samples were found and grouped as intended before QC starts.

```{r load_import_idat}
val <- validate_project(cfg, samples, fail_on_missing_idats = FALSE)
samples_resolved <- val$samples_resolved
idat_status <- val$idat_status
write_table(samples_resolved, "results/tables/samples_resolved.csv")
write_table(idat_status, "results/tables/idat_status.csv")
preflight <- idat_status %>%
  dplyr::left_join(
    samples_resolved %>% dplyr::select(sample_id, BasenameSource, EffectiveIdatBaseDir),
    by = "sample_id"
  ) %>%
  dplyr::mutate(
    idat_pair_ok = red_exists & grn_exists,
    missing_component = dplyr::case_when(
      !red_exists & !grn_exists ~ "both",
      !red_exists ~ "red",
      !grn_exists ~ "green",
      TRUE ~ "none"
    )
  )
write_table(preflight, "results/tables/idat_preflight.csv")
preflight_summary <- preflight %>%
  dplyr::count(BasenameSource, EffectiveIdatBaseDir, idat_pair_ok, name = "n_samples")
write_table(preflight_summary, "results/tables/idat_preflight_summary.csv")
if (any(!idat_status$red_exists | !idat_status$grn_exists)) {
  bad <- dplyr::filter(idat_status, !red_exists | !grn_exists)
  write_table(bad, "results/tables/missing_idats.csv")
  log_error("Missing IDAT pair(s) detected; see results/tables/idat_preflight.csv and results/tables/missing_idats.csv")
}
if (!requireNamespace("minfi", quietly = TRUE)) log_error("Package 'minfi' is required")
rgset <- minfi::read.metharray.exp(
  targets = as.data.frame(samples_resolved),
  recursive = isTRUE(cfg$idat$recursive),
  extended = TRUE
)
# Normalize all sample labels to samples.csv sample_id across the full report.
sample_name_map <- c(
  setNames(as.character(samples_resolved$sample_id), as.character(samples_resolved$Basename)),
  setNames(as.character(samples_resolved$sample_id), basename(as.character(samples_resolved$Basename))),
  setNames(as.character(samples_resolved$sample_id), as.character(samples_resolved$sample_id))
)
map_sample_id <- function(x) {
  x <- as.character(x)
  y <- unname(sample_name_map[x])
  ifelse(is.na(y) | y == "", x, y)
}
colnames(rgset) <- map_sample_id(colnames(rgset))
save_rds(rgset, "results/rds/rgset.rds")
log_info("Saved rgset to results/rds/rgset.rds")
```

